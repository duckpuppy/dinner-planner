{
  "name": "dinner-planner",
  "version": "1.9.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "turbo test",
    "type-check": "turbo type-check",
    "clean": "turbo clean && rm -rf node_modules",
    "db:generate": "pnpm --filter @dinner-planner/api db:generate",
    "db:migrate": "pnpm --filter @dinner-planner/api db:migrate",
    "db:studio": "pnpm --filter @dinner-planner/api db:studio",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "sh .githooks/pre-commit && pnpm type-check && pnpm lint && pnpm format:check",
    "post-merge": "sh .githooks/post-merge"
  },
  "pnpm": {
    "overrides": {
      "vite": "^8.0.0",
      "tar": ">=7.5.11",
      "esbuild": ">=0.25.0",
      "bn.js": ">=4.12.3",
      "minimatch": ">=10.2.3",
      "rollup@^4": "4.60.1",
      "rollup@^2": "4.59.0",
      "serialize-javascript": ">=7.0.3",
      "flatted": ">=3.4.0",
      "undici": ">=7.24.0",
      "picomatch": ">=4.0.4",
      "@xmldom/xmldom": ">=0.8.12",
      "lodash": ">=4.18.0"
    },
    "onlyBuiltDependencies": [
      "bcrypt",
      "better-sqlite3",
      "sharp",
      "simple-git-hooks"
    ],
    "auditConfig": {
      "ignoreCves": [
        "CVE-2026-34950",
        "CVE-2026-35042"
      ]
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "eslint": "^10.0.0",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-react-refresh": "^0.5.0",
    "prettier": "^3.4.2",
    "simple-git-hooks": "^2.13.1",
    "turbo": "^2.3.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1"
  }
}
