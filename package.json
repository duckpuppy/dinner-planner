{
  "name": "dinner-planner",
  "version": "1.18.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.14.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "turbo test",
    "type-check": "turbo type-check",
    "clean": "turbo clean && rm -rf node_modules",
    "db:generate": "pnpm --filter @dinner-planner/api db:generate",
    "db:migrate": "pnpm --filter @dinner-planner/api db:migrate",
    "db:studio": "pnpm --filter @dinner-planner/api db:studio",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "sh .githooks/pre-commit && pnpm type-check && pnpm lint && pnpm format:check",
    "post-merge": "sh .githooks/post-merge"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "eslint": "^10.0.0",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-react-refresh": "^0.5.0",
    "prettier": "^3.4.2",
    "simple-git-hooks": "^2.13.1",
    "turbo": "^2.3.0",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.18.1"
  }
}
