{
  "name": "dinner-planner",
  "version": "1.2.2",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "turbo test",
    "type-check": "turbo type-check",
    "clean": "turbo clean && rm -rf node_modules",
    "db:generate": "pnpm --filter @dinner-planner/api db:generate",
    "db:migrate": "pnpm --filter @dinner-planner/api db:migrate",
    "db:studio": "pnpm --filter @dinner-planner/api db:studio",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm type-check && pnpm lint && pnpm format:check"
  },
  "pnpm": {
    "overrides": {
      "tar": ">=7.5.8",
      "minimatch": ">=10.2.3",
      "rollup@^4": "4.59.0",
      "rollup@^2": "2.80.0",
      "serialize-javascript": ">=7.0.3"
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "prettier": "^3.4.2",
    "simple-git-hooks": "^2.13.1",
    "turbo": "^2.3.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1"
  }
}
