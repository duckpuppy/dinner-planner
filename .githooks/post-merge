#!/usr/bin/env sh
# .githooks/post-merge — re-import beads issues.jsonl after git pull/merge
#
# Ensures local Dolt database stays in sync after pulling new issues from remote.
# Installed automatically via simple-git-hooks on pnpm install.

command -v bd >/dev/null 2>&1 || exit 0

REPO_ROOT=$(git rev-parse --show-toplevel)
JSONL="$REPO_ROOT/.beads/issues.jsonl"

[ -f "$JSONL" ] || exit 0

# Import JSONL into local Dolt database
# "nothing to commit" is normal when data is already up-to-date
bd import "$JSONL" 2>&1 | grep -v "nothing to commit" || true

exit 0
