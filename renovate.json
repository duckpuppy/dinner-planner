{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "packageRules": [
    {
      "groupName": "Safe Minor & Patch Updates",
      "matchUpdateTypes": ["minor", "patch"],
      "labels": ["dependencies"],
      "matchPackageNames": ["!/react/", "!/typescript/"]
    },
    // Handle excluded packages with separate PRs
    {
      "groupName": "Critical Minor & Patch (react/typescript)",
      "matchUpdateTypes": ["minor", "patch"],
      "labels": ["critical-dependencies"],
      "matchPackageNames": ["/react/", "/typescript/"]
    },
    {
      "matchPackageNames": ["undici"],
      "allowedVersions": "^7",
      "description": "Pin undici to 7.x — jsdom@29.0.1 imports undici internals removed in v8"
    },
    {
      "matchFileNames": ["Dockerfile", ".mise.toml"],
      "matchPackageNames": ["node"],
      "allowedVersions": "22",
      "description": "Pin Node.js to 22 LTS — better-sqlite3 native rebuild fails on Node 24 with node-gyp ENOENT bug"
    }
  ]
}
