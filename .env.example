# Server
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Database
DATABASE_URL=file:./data/dinner.db

# JWT (generate with: openssl rand -base64 32)
JWT_SECRET=your-secret-key-at-least-32-characters-long
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Initial admin user (only used on first run if no users exist)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# CORS
CORS_ORIGIN=http://localhost:5173

# Video & LLM Configuration (optional)
# OLLAMA_URL=http://192.168.0.250:11434    # Ollama instance URL
# OLLAMA_MODEL=gemma4-e4b                  # Default Ollama model
# LLM_MODE=disabled                        # disabled | direct | n8n
# N8N_WEBHOOK_URL=                         # n8n webhook URL (when LLM_MODE=n8n)
# VIDEO_STORAGE_LIMIT_MB=10240             # Max video storage in MB (default 10GB)
