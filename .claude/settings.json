{
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(bd)",
      "Bash(bd :*)",
      "Bash(pnpm:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(/home/duckpuppy/.local/bin/mise exec:*)",
      "Bash(bash .claude/hooks:*)",
      "Bash(curl:*)",
      "Bash(corepack enable:*)",
      "Bash(source:*)",
      "Bash(export:*)",
      "mcp__filesystem__list_directory",
      "mcp__filesystem__read_multiple_files",
      "Skill(beads:beads)"
    ]
  },
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "bd prime",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": ".claude/hooks/block-orchestrator-tools.sh",
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": ".claude/hooks/enforce-branch-before-edit.sh",
            "type": "command"
          }
        ],
        "matcher": "Edit"
      },
      {
        "hooks": [
          {
            "command": ".claude/hooks/enforce-branch-before-edit.sh",
            "type": "command"
          }
        ],
        "matcher": "Write"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": ".claude/hooks/session-start.sh",
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "bd prime",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": ".claude/hooks/clarify-vague-request.sh",
            "type": "command"
          }
        ]
      }
    ]
  }
}